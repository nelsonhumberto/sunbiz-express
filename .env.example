# Copy this to .env and fill in the values from your Supabase project.
# Settings → Database → Connection string

# Pooled (required for serverless / Vercel)
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct (used by `prisma migrate` only)
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# Must match `npm run dev` — see package.json (fixed port 3333 avoids clashes with other apps on 3000).
NEXTAUTH_URL="http://localhost:3333"

# ─── Payments demo mode ──────────────────────────────────────────────────
#
# When set to "true", the checkout step shows the "(demo mode)" badge and
# pre-fills the test card values used to exercise the mock checkout. Leave
# unset/false in production-like builds so the form starts blank and the
# trust copy stays neutral ("Secured payment · TLS-encrypted").
NEXT_PUBLIC_PAYMENTS_DEMO_MODE="false"

# ─── Stripe (real payments) ───────────────────────────────────────────────
#
# Get these from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_... / pk_test_...) for local dev and staging.
# Use live keys (sk_live_... / pk_live_...) in production only.
#
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
#
# Webhook secret — from `stripe listen --forward-to localhost:3333/api/stripe/webhook`
# or from the Stripe dashboard (Developers → Webhooks → your endpoint → Signing secret).
# STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Florida Sunbiz name-availability lookup ─────────────────────────────
#
# Resolution order in lib/sunbiz.ts:
#   1. SUNBIZDAILY_API_KEY  → call sunbizdaily.com REST API     (recommended)
#   2. SUNBIZ_SCRAPER_PROXY → scrape via CF-bypass proxy        (filing-time use)
#   3. neither              → direct scrape (will hit Cloudflare; clear error)
#
# The live search.sunbiz.org site is gated by Cloudflare and cannot be reached
# from a plain serverless fetch. Set at least one of the variables below.

# Primary: third-party JSON mirror of Sunbiz's daily bulk feed.
# Free tier, 1,000 requests/hour. Sign up at https://sunbizdaily.com/
# Format: sb_<32 chars>
# SUNBIZDAILY_API_KEY=""

# ─── Local Sunbiz cloudscraper sidecar (dev / no paid proxy needed) ─────────
#
# When set, entity lookups call this local Python service instead of Sunbiz Daily.
# Start it with:
#   cd scripts/sunbiz-scraper && pip install -r requirements.txt && python app.py
# Then add this to .env.local:
#   SUNBIZ_LOCAL_PROXY_URL="http://localhost:3334"
#
# SUNBIZ_LOCAL_PROXY_URL=""

# (Optional) Cloudflare-bypass proxy for the live search.sunbiz.org scraper.
# Used by `searchSunbizScrape()` for the Phase-2 final ground-truth check
# at filing time. Point this at a passthrough proxy that returns raw HTML.
#   - If the value contains "{url}", it is replaced with the URL-encoded target.
#   - Otherwise we append "?url=<target>" to the proxy URL.
# Examples:
#   ScrapingBee:  https://app.scrapingbee.com/api/v1/?api_key=KEY&render_js=false&url={url}
#   ScraperAPI:   https://api.scraperapi.com/?api_key=KEY&url={url}
#   FlareSolverr: not directly compatible (POST API) — front it with a small adapter.
# SUNBIZ_SCRAPER_PROXY=""
